# Secrets for local `supabase functions serve`. Copy to supabase/functions/.env
# (gitignored) and fill in real values. On hosted, set these via `supabase secrets set`.

# Anthropic API key for the ask-pamwe (Ask Pamwe) edge function.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (default claude-haiku-4-5). Must support structured
# outputs (Haiku 4.5, Sonnet 5, Opus 4.8, Fable 5).
# ANTHROPIC_MODEL=claude-haiku-4-5
