# generated native folders (ExportOptions.plist is the one keeper: the
# TestFlight upload step needs it and it holds no secrets)
/ios/*
!/ios/ExportOptions.plist
# VerseWidget is hand-authored source (Swift + assets + fonts + verses.json), not
# generated by prebuild. Keep it in git. The .xcodeproj stays ignored but the
# target is reproducible via scripts/add_widget_target.rb.
!/ios/VerseWidget/
/android

# local env files (Supabase keys, Google client IDs, Sentry DSN)
.env
env.hosted.backup

